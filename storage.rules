rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public reads (product images, mockups)
    match /{allPaths=**} {
      allow read: if true;
    }
    // Admin uploads — allow any authenticated user (including anonymous)
    // Falls back to allowing all writes if anonymous auth is not enabled
    match /uploads/{allPaths=**} {
      allow write: if true;
    }
    match /products/{allPaths=**} {
      allow write: if true;
    }
    match /content/{allPaths=**} {
      allow write: if true;
    }
    match /mockups/{allPaths=**} {
      allow write: if true;
    }
  }
}
